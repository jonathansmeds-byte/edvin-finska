\pard\sa200\sl276\slmult1\f0\fs22\lang9 <!doctype html>\par
<html lang="sv">\par
<head>\par
  <meta charset="utf-8" />\par
  <meta name="viewport" content="width=device-width, initial-scale=1" />\par
  <title>Finska test \f1\endash  Niv\f0\'e5 1\f1\endash 2</title>\par
  <style>\par
    :root \{ --pad: 16px; \}\par
    body \{ font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; margin: 0; background:#0b0c10; color:#eaf0ff; \}\par
